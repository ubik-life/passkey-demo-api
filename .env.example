# Listen address (default: :8080)
SERVICE_ADDR=:8080

# SQLite database path (required)
SQLITE_PATH=/var/lib/passkey/data.db

# WebAuthn Relying Party (default: Passkey Demo / localhost)
PASSKEY_RP_NAME=Passkey Demo
PASSKEY_RP_ID=localhost

# Challenge TTL (default: 5m)
PASSKEY_CHALLENGE_TTL=5m

# JWT TTL — reserved for slices 2/4
PASSKEY_JWT_ACCESS_TTL=15m
PASSKEY_JWT_REFRESH_TTL=720h
