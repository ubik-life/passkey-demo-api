# Профиль для сценария db_disk_full. SQLite живёт на tmpfs минимального
# размера; тест перед сценарием заполняет tmpfs junk-файлом до отказа.
# При первой записи SUT получает SQLITE_FULL и должен отдать
# 507 Insufficient Storage с error.code=db_disk_full.
SQLITE_PATH=/var/lib/passkey/data.db
SQLITE_MOUNT_TYPE=tmpfs
SQLITE_TMPFS_SIZE=2m
